FROM python:3.12-slim

WORKDIR /app

RUN pip install --no-cache-dir \
    fastapi==0.135.3 \
    "uvicorn[standard]==0.34.0" \
    requests==2.32.3 \
    aiohttp==3.11.13 \
    beautifulsoup4==4.12.3 \
    certifi==2025.4.26 \
    python-dotenv==1.0.1

COPY src/ src/
COPY parser_api.py .

CMD ["uvicorn", "parser_api:app", "--host", "0.0.0.0", "--port", "8001"]
